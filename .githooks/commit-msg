#!/usr/bin/env sh
set -eu

msg_file="${1:-}"
if [ -z "$msg_file" ] || [ ! -f "$msg_file" ]; then
  echo "commit-msg hook: message file not found." >&2
  exit 1
fi

subject="$(head -n 1 "$msg_file" | tr -d '\r')"

# Merge/revert/fixup/squash 커밋은 기본 git 플로우를 깨지 않도록 허용한다.
if printf '%s\n' "$subject" | grep -Eq '^(Merge |Revert "|fixup!|squash!)'; then
  exit 0
fi

pattern='^(feat|fix|refactor|docs|test|chore|ci|build|perf|revert)(\([a-z0-9._/-]+\))?!?: .+'
if printf '%s\n' "$subject" | grep -Eq "$pattern"; then
  exit 0
fi

echo "Invalid commit message: $subject" >&2
echo "Expected: type(scope): subject" >&2
echo "Allowed types: feat|fix|refactor|docs|test|chore|ci|build|perf|revert" >&2
exit 1
